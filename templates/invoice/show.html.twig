{% extends 'base.html.twig' %}

{% block title %}Facture {{ invoice.numberInvoice }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">

            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-5">
                <div>
                    <h1 class="h2 mb-1">Facture</h1>
                    <p class="text-muted mb-0">Détail de la facture {{ invoice.numberInvoice }}</p>
                </div>

                <div class="text-md-end">
                    <div class="mb-2">
                        <span class="text-muted d-block small text-uppercase">Numéro</span>
                        <strong>{{ invoice.numberInvoice }}</strong>
                    </div>
                    <div>
                        <span class="text-muted d-block small text-uppercase">Date</span>
                        <strong>{{ invoice.saleDate ? invoice.saleDate|date('d/m/Y') : '' }}</strong>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <div class="border rounded p-4 h-100 bg-light">
                        <h2 class="h6 text-uppercase text-muted mb-3">Vendeur</h2>
                        <p class="mb-1 fw-semibold">
                            {{ invoice.seller.firstNameSeller }} {{ invoice.seller.lastNameSeller }}
                        </p>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="border rounded p-4 h-100 bg-light">
                        <h2 class="h6 text-uppercase text-muted mb-3">Client</h2>
                        <p class="mb-1 fw-semibold">
                            {{ invoice.customer.firstNameCustomer }} {{ invoice.customer.lastNameCustomer }}
                        </p>
                    </div>
                </div>
            </div>

            <div class="border rounded overflow-hidden mb-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Produit</th>
                                <th>Marque</th>
                                <th class="text-end">Prix unitaire</th>
                                <th class="text-center">Quantité</th>
                                <th class="text-end">Total ligne</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in invoice.invoiceItems %}
                                <tr>
                                    <td class="fw-medium">{{ item.productName }}</td>
                                    <td>{{ item.brand }}</td>
                                    <td class="text-end">{{ item.price|number_format(2, ',', ' ') }} €</td>
                                    <td class="text-center">{{ item.quantity }}</td>
                                    <td class="text-end fw-semibold">{{ item.total|number_format(2, ',', ' ') }} €</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        Aucune ligne de facture
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>

                        {% if invoice.invoiceItems|length > 0 %}
                            <tfoot>
                                <tr>
                                    <th colspan="4" class="text-end py-3">Total général</th>
                                    <th class="text-end py-3 fs-5">{{ invoice.grandTotal|number_format(2, ',', ' ') }} €</th>
                                </tr>
                            </tfoot>
                        {% endif %}
                    </table>
                </div>
            </div>

            <div class="d-flex justify-content-between flex-wrap gap-2 mt-4">
                <div>
                    {{ include('components/buttons/_back.html.twig', {
                        route: 'app_invoice_index'
                    }) }}
                </div>

                <div class="d-flex gap-2">
                    <a href="{{ path('app_invoice_pdf', {id: invoice.id}) }}" class="btn btn-outline-dark">
                        Voir PDF
                    </a>

                    {{ include('components/buttons/_edit.html.twig', {
                        route: 'app_invoice_edit',
                        id: invoice.id
                    }) }}

                    {{ include('components/buttons/_delete.html.twig', {
                        route: 'app_invoice_delete',
                        id: invoice.id
                    }) }}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}