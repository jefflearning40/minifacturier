{% extends 'base.html.twig' %}

{% block title %}Détail facture{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="mb-4">Détail facture</h1>

    {{ include('components/facture/_facture_info.html.twig', {
        invoice: invoice
    }) }}

    <div class="d-flex justify-content-between mb-5">
        {{ include('components/buttons/_back.html.twig', {
            route: 'app_invoice_index'
        }) }}

        <div>
            {{ include('components/buttons/_edit.html.twig', {
                route: 'app_invoice_edit',
                id: invoice.id
            }) }}

            {{ include('components/buttons/_delete.html.twig', {
                route: 'app_invoice_delete',
                id: invoice.id
            }) }}
        </div>
    </div>

    <h2 class="mb-3">Lignes de facture ({{ invoice.invoiceItems|length }})</h2>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Produit</th>
                <th>Marque</th>
                <th>Prix</th>
                <th>Qté</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
        {% for item in invoice.invoiceItems %}
            <tr>
                <td>{{ item.id }}</td>
                <td>{{ item.productName }}</td>
                <td>{{ item.brand }}</td>
                <td>{{ item.price }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.total }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center">
                    Aucune ligne de facture
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %}