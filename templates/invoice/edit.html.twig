{% extends 'base.html.twig' %}

{% block title %}Modifier la facture{% endblock %}

{% block main_class %}container-fluid p-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/invoice.css') }}">
{% endblock %}

{% block body %}
<section class="invoice-form-section">

    <div class="invoice-form-wrapper">

        <h1>Modifier la facture</h1>

        <div class="invoice-form-box">
            {{ include('invoice/_form.html.twig', {
                form: form,
                button_label: 'Mettre à jour'
            }) }}
        </div>

        <div class="invoice-form-actions d-flex justify-content-between">
            {{ include('components/buttons/_back.html.twig', {
                route: 'app_invoice_index'
            }) }}

            {{ include('components/buttons/_delete.html.twig', {
                route: 'app_invoice_delete',
                id: invoice.id
            }) }}
        </div>

    </div>

</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/invoice.js') }}"></script>
{% endblock %}