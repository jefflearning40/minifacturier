{% extends 'base.html.twig' %}

{% block title %}Modifier facture{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="mb-4">Modifier facture</h1>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">

            {{ include('invoice/_form.html.twig', {
                button_label: 'Modifier',
                button_class: 'btn-primary'
            }) }}

            <div class="d-flex justify-content-between mt-4">

                {{ include('components/buttons/_back.html.twig', {
                    route: 'app_invoice_index'
                }) }}

                {{ include('components/buttons/_delete.html.twig', {
                    route: 'app_invoice_delete',
                    id: invoice.id
                }) }}

            </div>

        </div>
    </div>

</div>
{% endblock %}