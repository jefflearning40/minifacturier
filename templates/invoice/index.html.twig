{% extends 'base.html.twig' %}

{% block title %}Invoice index{% endblock %}

{% block body %}
    <h1>Invoice index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>NumberInvoice</th>
                <th>DescriptionItem</th>
                <th>PriceItem</th>
                <th>Qty</th>
                <th>Total</th>
                <th>SaleDate</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for invoice in invoices %}
            <tr>
                <td>{{ invoice.id }}</td>
                <td>{{ invoice.numberInvoice }}</td>
                <td>{{ invoice.descriptionItem }}</td>
                <td>{{ invoice.priceItem }}</td>
                <td>{{ invoice.qty }}</td>
                <td>{{ invoice.total }}</td>
                <td>{{ invoice.saleDate ? invoice.saleDate|date('Y-m-d') : '' }}</td>
                <td>
                    <a href="{{ path('app_invoice_show', {'id': invoice.id}) }}">show</a>
                    <a href="{{ path('app_invoice_edit', {'id': invoice.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_invoice_new') }}">Create new</a>
{% endblock %}
