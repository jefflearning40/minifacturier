{% extends 'base.html.twig' %}

{% block title %}Liste des factures{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Liste des factures</h1>

        <a href="{{ path('app_invoice_new') }}" class="btn btn-success">
            + Nouvelle facture
        </a>
    </div>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Numéro</th>
                <th>Description</th>
                <th>Prix</th>
                <th>Qté</th>
                <th>Total</th>
                <th>Date</th>
                <th>Vendeur</th>
                <th>Client</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for invoice in invoices %}
            <tr>
                <td>{{ invoice.id }}</td>
                <td>{{ invoice.numberInvoice }}</td>
                <td>{{ invoice.descriptionItem }}</td>
                <td>{{ invoice.priceItem }}</td>
                <td>{{ invoice.qty }}</td>
                <td>{{ invoice.total }}</td>
                <td>{{ invoice.saleDate ? invoice.saleDate|date('d/m/Y') : '' }}</td>
                <td>
                    {% if invoice.seller %}
                        {{ invoice.seller.firstNameSeller }} {{ invoice.seller.lastNameSeller|upper }}
                    {% endif %}
                </td>
                <td>
                    {% if invoice.customer %}
                        {{ invoice.customer.firstNameCustomer }} {{ invoice.customer.lastNameCustomer|upper }}
                    {% endif %}
                </td>
                <td class="text-center">
                    {{ include('components/buttons/_show.html.twig', {
                        route: 'app_invoice_show',
                        id: invoice.id
                    }) }}

                    {{ include('components/buttons/_edit.html.twig', {
                        route: 'app_invoice_edit',
                        id: invoice.id
                    }) }}

                    {{ include('components/buttons/_delete.html.twig', {
                        route: 'app_invoice_delete',
                        id: invoice.id,
                        size: 'btn-sm'
                    }) }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10" class="text-center">Aucune facture trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-4">

        {{ include('components/buttons/_prev.html.twig', {
            pagination: invoices
        }) }}

        <span class="fw-bold">
            Page {{ invoices.currentPageNumber }} / {{ invoices.pageCount }}
        </span>

        {{ include('components/buttons/_next.html.twig', {
            pagination: invoices
        }) }}

    </div>

    <div class="text-center text-muted mt-2">
        {{ invoices.getTotalItemCount }} factures au total
    </div>

</div>
{% endblock %}