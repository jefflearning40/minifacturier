{% extends 'base.html.twig' %}

{% block title %}Liste des factures{% endblock %}

{% block main_class %}container-fluid p-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/invoice.css') }}">
{% endblock %}

{% block body %}
<section class="invoice-section">

    <div class="invoice-wrapper">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Liste des factures</h1>
        </div>

        <div class="invoice-table-wrapper">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th>Id</th>
                        <th>Numéro</th>
                        <th>Produit</th>
                        <th>Marque</th>
                        <th>Prix</th>
                        <th>Qté</th>
                        <th>Total</th>
                        <th>Date</th>
                        <th>Vendeur</th>
                        <th>Client</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

               <tbody>
{% for invoice in invoices %}
    {% set mainItem = invoice.mainItem %}

    <tr>
        <td>{{ invoice.id }}</td>
        <td>{{ invoice.numberInvoice }}</td>

        <td>
            {% if mainItem %}
                {{ mainItem.productName }}

                {% if invoice.otherItemsCount > 0 %}
                    <span class="badge bg-secondary ms-2">
                        + {{ invoice.otherItemsCount }} autre{% if invoice.otherItemsCount > 1 %}s{% endif %}
                    </span>
                {% endif %}
            {% else %}
                <span class="text-muted">Aucune ligne</span>
            {% endif %}
        </td>

        <td>
            {% if mainItem %}
                {{ mainItem.brand }}
            {% else %}
                <span class="text-muted">-</span>
            {% endif %}
        </td>

        <td>
            {% if mainItem %}
                {{ mainItem.price|number_format(2, ',', ' ') }}
            {% else %}
                <span class="text-muted">-</span>
            {% endif %}
        </td>

        <td>
            {% if mainItem %}
                {{ mainItem.quantity }}
            {% else %}
                <span class="text-muted">-</span>
            {% endif %}
        </td>

        <td>
            {{ invoice.grandTotal|number_format(2, ',', ' ') }}
        </td>

        <td>{{ invoice.saleDate ? invoice.saleDate|date('d/m/Y') : '' }}</td>

        <td>
            {% if invoice.seller %}
                {{ invoice.seller.firstNameSeller }} {{ invoice.seller.lastNameSeller|upper }}
            {% endif %}
        </td>

        <td>
            {% if invoice.customer %}
                {{ invoice.customer.firstNameCustomer }} {{ invoice.customer.lastNameCustomer|upper }}
            {% endif %}
        </td>

        <td class="text-center">
            {{ include('components/buttons/_show.html.twig', {
                route: 'app_invoice_show',
                id: invoice.id
            }) }}

            {{ include('components/buttons/_edit.html.twig', {
                route: 'app_invoice_edit',
                id: invoice.id
            }) }}

            {{ include('components/buttons/_delete.html.twig', {
                route: 'app_invoice_delete',
                id: invoice.id,
                size: 'btn-sm'
            }) }}
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="11" class="text-center">
            Aucune facture trouvée
        </td>
    </tr>
{% endfor %}
</tbody>
            </table>
        </div>

        <div class="invoice-pagination d-flex justify-content-center align-items-center gap-3 mt-4">

            {{ include('components/buttons/_prev.html.twig', {
                pagination: invoices
            }) }}

            <span class="fw-bold">
                Page {{ invoices.currentPageNumber }} / {{ invoices.pageCount }}
            </span>

            {{ include('components/buttons/_next.html.twig', {
                pagination: invoices
            }) }}

        </div>

        <div class="invoice-total text-center mt-2">
            {{ invoices.getTotalItemCount }} factures au total
        </div>

    </div>

</section>
{% endblock %}