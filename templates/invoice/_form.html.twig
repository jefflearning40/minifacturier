{{ form_start(form) }}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="h4 mb-1">Facture</h2>
        <p class="text-muted mb-0">Création / modification</p>
    </div>

    <div class="text-end">
        <div class="alert alert-info py-2 px-3 mb-3">
            Le numéro de facture sera généré automatiquement.
        </div>

        <div>
            {{ form_label(form.saleDate) }}
            {{ form_widget(form.saleDate, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.saleDate) }}
        </div>
    </div>
</div>

<div class="row mb-4">
    {% if form.seller is defined %}
        <div class="col-md-6">
            <div class="border rounded p-3 h-100 bg-light-subtle">
                <h3 class="h6 text-uppercase text-muted mb-3">Vendeur</h3>
                {{ form_row(form.seller) }}
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3 h-100 bg-light-subtle">
                <h3 class="h6 text-uppercase text-muted mb-3">Client</h3>
                {{ form_row(form.customer) }}
            </div>
        </div>
    {% else %}
        <div class="col-md-12">
            <div class="border rounded p-3 h-100 bg-light-subtle">
                <h3 class="h6 text-uppercase text-muted mb-3">Client</h3>
                {{ form_row(form.customer) }}
            </div>
        </div>
    {% endif %}
</div>

<div class="alert alert-warning d-none" id="invoice-alert">
    Veuillez sélectionner un produit et une quantité valide.
</div>

<div class="border rounded overflow-hidden mb-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Produit</th>
                    <th>Prix</th>
                    <th>Qté</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody id="invoice-items-wrapper">
                {% for itemForm in form.invoiceItems %}
                    <tr class="invoice-item">
                        <td>{{ form_widget(itemForm.product) }}</td>
                        <td>{{ form_widget(itemForm.price) }}</td>
                        <td>{{ form_widget(itemForm.quantity) }}</td>
                        <td>
                            <div class="form-control bg-light text-end fw-semibold line-total-display">
                                0.00 €
                            </div>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-outline-danger btn-sm remove-item">
                                ✕
                            </button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div
    id="invoice-item-prototype"
    data-prototype="
        <tr class='invoice-item'>
            <td>{{ form_widget(form.invoiceItems.vars.prototype.product)|e('html_attr') }}</td>
            <td>{{ form_widget(form.invoiceItems.vars.prototype.price)|e('html_attr') }}</td>
            <td>{{ form_widget(form.invoiceItems.vars.prototype.quantity)|e('html_attr') }}</td>
            <td>
                <div class='form-control bg-light text-end fw-semibold line-total-display'>
                    0.00 €
                </div>
            </td>
            <td class='text-center'>
                <button type='button' class='btn btn-outline-danger btn-sm remove-item'>
                    ✕
                </button>
            </td>
        </tr>
    "
></div>

<div class="d-flex justify-content-between align-items-center mt-4">
    <button type="button" id="add-invoice-item" class="btn btn-outline-dark">
        + Ligne produit
    </button>

    <div class="border rounded px-4 py-2 bg-light text-end">
        <div class="small text-muted">Total HT</div>
        <div class="fw-bold" id="invoice-grand-total">0.00 €</div>
    </div>
</div>

<div class="d-flex justify-content-end mt-4">
    <button class="btn btn-primary px-4" id="invoice-submit" disabled>
        {{ button_label|default('Enregistrer') }}
    </button>
</div>

{{ form_end(form) }}