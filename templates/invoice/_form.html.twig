{{ form_start(form) }}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h1 class="h3 mb-1">Facture</h1>
                    <p class="text-muted mb-0">Création / modification d'une facture</p>
                </div>
                <div class="text-end">
                    <div class="mb-3">
                        {{ form_label(form.numberInvoice) }}
                        {{ form_widget(form.numberInvoice, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.numberInvoice) }}
                    </div>
                    <div>
                        {{ form_label(form.saleDate) }}
                        {{ form_widget(form.saleDate, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.saleDate) }}
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="border rounded p-3 h-100 bg-light-subtle">
                        <h2 class="h6 text-uppercase text-muted mb-3">Vendeur</h2>
                        {{ form_row(form.seller) }}
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="border rounded p-3 h-100 bg-light-subtle">
                        <h2 class="h6 text-uppercase text-muted mb-3">Client</h2>
                        {{ form_row(form.customer) }}
                    </div>
                </div>
            </div>

            <div class="border rounded overflow-hidden mb-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="min-width: 320px;">Produit</th>
                                <th style="min-width: 140px;">Prix unitaire</th>
                                <th style="min-width: 120px;">Quantité</th>
                                <th style="min-width: 140px;">Total ligne</th>
                                <th style="width: 120px;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="invoice-items-wrapper">
                            {% for itemForm in form.invoiceItems %}
                                <tr class="invoice-item">
                                    <td>
                                        {{ form_widget(itemForm.product) }}
                                        {{ form_errors(itemForm.product) }}
                                    </td>
                                    <td>
                                        {{ form_widget(itemForm.price) }}
                                        {{ form_errors(itemForm.price) }}
                                    </td>
                                    <td>
                                        {{ form_widget(itemForm.quantity) }}
                                        {{ form_errors(itemForm.quantity) }}
                                    </td>
                                    <td>
                                        <div class="form-control bg-light text-end fw-semibold line-total-display">0.00 €</div>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-outline-danger btn-sm remove-item">
                                            Supprimer
                                        </button>
                                    </td>
                                </tr>
                            {% else %}
                                <tr class="invoice-item-empty-placeholder d-none">
                                    <td colspan="5" class="text-center text-muted py-4">
                                        Aucune ligne de facture
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div
                id="invoice-item-prototype"
                data-prototype="
                    <tr class='invoice-item'>
                        <td>
                            {{ form_widget(form.invoiceItems.vars.prototype.product)|e('html_attr') }}
                        </td>
                        <td>
                            {{ form_widget(form.invoiceItems.vars.prototype.price)|e('html_attr') }}
                        </td>
                        <td>
                            {{ form_widget(form.invoiceItems.vars.prototype.quantity)|e('html_attr') }}
                        </td>
                        <td>
                            <div class='form-control bg-light text-end fw-semibold line-total-display'>0.00 €</div>
                        </td>
                        <td class='text-center'>
                            <button type='button' class='btn btn-outline-danger btn-sm remove-item'>
                                Supprimer
                            </button>
                        </td>
                    </tr>
                "
            ></div>

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-4">
                <button type="button" id="add-invoice-item" class="btn btn-outline-dark">
                    Ajouter une ligne produit
                </button>

                <div class="ms-auto">
                    <div class="border rounded px-4 py-3 bg-light">
                        <div class="small text-muted text-uppercase mb-1">Total général</div>
                        <div class="fs-4 fw-bold" id="invoice-grand-total">0.00 €</div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button class="btn btn-primary px-4">
                    {{ button_label|default('Enregistrer') }}
                </button>
            </div>

        </div>
    </div>
</div>

{{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function () {
    const wrapper = document.getElementById('invoice-items-wrapper');
    const prototypeHolder = document.getElementById('invoice-item-prototype');
    const addButton = document.getElementById('add-invoice-item');
    const grandTotalElement = document.getElementById('invoice-grand-total');

    let index = wrapper.querySelectorAll('.invoice-item').length;

    function toNumber(value) {
        if (!value) {
            return 0;
        }

        return parseFloat(String(value).replace(',', '.').replace(' €', '')) || 0;
    }

    function updateFromProduct(item) {
        const select = item.querySelector('select');
        const priceInput = item.querySelector('input[id*="_price"]');

        if (!select || select.selectedIndex < 0) {
            return;
        }

        const selectedText = select.options[select.selectedIndex]?.text || '';

        if (!selectedText || selectedText.includes('Choisissez un produit')) {
            if (priceInput) {
                priceInput.value = '';
            }
            return;
        }

        const parts = selectedText.split(' - ');

        if (parts.length >= 3) {
            const price = parts[2].replace(' €', '').trim();

            if (priceInput) {
                priceInput.value = price;
            }
        }
    }

    function updateLineTotal(item) {
        const priceInput = item.querySelector('input[id*="_price"]');
        const quantityInput = item.querySelector('input[id*="_quantity"]');
        const totalDisplay = item.querySelector('.line-total-display');

        if (!priceInput || !quantityInput || !totalDisplay) {
            return 0;
        }

        const price = toNumber(priceInput.value);
        const quantity = toNumber(quantityInput.value);
        const total = price * quantity;

        totalDisplay.textContent = total.toFixed(2) + ' €';

        return total;
    }

    function updateGrandTotal() {
        let grandTotal = 0;

        wrapper.querySelectorAll('.invoice-item').forEach(item => {
            grandTotal += updateLineTotal(item);
        });

        grandTotalElement.textContent = grandTotal.toFixed(2) + ' €';
    }

    function bindCalculationEvents(item) {
        const select = item.querySelector('select');
        const priceInput = item.querySelector('input[id*="_price"]');
        const quantityInput = item.querySelector('input[id*="_quantity"]');
        const removeButton = item.querySelector('.remove-item');

        if (select) {
            select.addEventListener('change', function () {
                updateFromProduct(item);
                updateGrandTotal();
            });
        }

        [priceInput, quantityInput].forEach(input => {
            if (input) {
                input.addEventListener('input', function () {
                    updateGrandTotal();
                });
            }
        });

        if (removeButton) {
            removeButton.addEventListener('click', function () {
                item.remove();
                updateGrandTotal();
            });
        }

        if (select && !select.value) {
            select.value = '';
        }

        updateFromProduct(item);
        updateLineTotal(item);
    }

    if (addButton) {
        addButton.addEventListener('click', function () {
            let prototype = prototypeHolder.dataset.prototype;
            prototype = prototype.replace(/__name__/g, index);

            const temp = document.createElement('tbody');
            temp.innerHTML = prototype.trim();

            const newItem = temp.firstElementChild;
            wrapper.appendChild(newItem);

            bindCalculationEvents(newItem);
            updateGrandTotal();

            index++;
        });
    }

    wrapper.querySelectorAll('.invoice-item').forEach(item => {
        bindCalculationEvents(item);
    });

    updateGrandTotal();
});
</script>