{% extends 'base.html.twig' %}

{% block title %}Modifier fiche client{% endblock %}

{% block main_class %}container-fluid px-0 pt-4 pb-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/customer.css') }}">
{% endblock %}

{% block body %}
<section class="customer-form-section">

    <div class="customer-form-card">

        <h1 class="mb-4">Modifier données client</h1>

        {{ include('customer/_form.html.twig', {
            button_label: 'Modifier',
            button_class: 'btn-primary'
        }) }}

        <div class="d-flex justify-content-between mt-4">

            {{ include('components/buttons/_back.html.twig', {
                route: 'app_customer_index'
            }) }}

            {{ include('components/buttons/_delete.html.twig', {
                route: 'app_customer_delete',
                id: customer.id
            }) }}

        </div>

    </div>

</section>
{% endblock %}