{% extends 'base.html.twig' %}

{% block title %}MiniFacturier{% endblock %}

{% block body %}
<div class="d-flex flex-column justify-content-center" style="min-height: calc(100vh - 200px);">

    <div class="text-center mb-3">
        <h1 class="fw-bold mb-1">MiniFacturier</h1>
        <p class="text-muted small mb-0">Gestion des vendeurs, clients et factures</p>
    </div>

    <div class="row g-3 row-gap-4 justify-content-center">

        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-4 p-3 text-center h-100">
                <i class="fa-solid fa-user-group text-primary fs-4 mb-2"></i>
                <h3 class="h6 fw-bold mb-1">Clients</h3>
                <p class="text-muted small mb-2">Gérez vos clients</p>
                <a href="{{ path('app_customer_index') }}" class="btn btn-primary btn-sm w-100">Voir</a>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-4 p-3 text-center h-100">
                <i class="fa-solid fa-user-tie text-success fs-4 mb-2"></i>
                <h3 class="h6 fw-bold mb-1">Vendeurs</h3>
                <p class="text-muted small mb-2">Gérez vos vendeurs</p>
                <a href="{{ path('app_seller_index') }}" class="btn btn-success btn-sm w-100">Voir</a>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-4 p-3 text-center h-100">
                <i class="fa-solid fa-file-invoice-dollar text-warning fs-4 mb-2"></i>
                <h3 class="h6 fw-bold mb-1">Factures</h3>
                <p class="text-muted small mb-2">Suivi des factures</p>
                <a href="{{ path('app_invoice_index') }}" class="btn btn-warning btn-sm w-100">Voir</a>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="border rounded-4 p-3 text-center h-100">
                <i class="fa-solid fa-book text-dark fs-4 mb-2"></i>
                <h3 class="h6 fw-bold mb-1">Catalogue</h3>
                <p class="text-muted small mb-2">Produits</p>
                <a href="{{ path('app_catalog_index') }}" class="btn btn-dark btn-sm w-100">Voir</a>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SELLER') %}
            <div class="col-sm-6 col-lg-3">
                <div class="border rounded-4 p-3 text-center h-100">
                    <i class="fa-solid fa-chart-pie text-info fs-4 mb-2"></i>
                    <h3 class="h6 fw-bold mb-1">Stats</h3>
                    <p class="text-muted small mb-2">Performances</p>
                    <a
                        href="{% if is_granted('ROLE_ADMIN') %}{{ path('app_statistics_admin') }}{% else %}{{ path('app_statistics_seller') }}{% endif %}"
                        class="btn btn-info btn-sm text-white w-100"
                    >
                        Voir
                    </a>
                </div>
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}