{% extends 'base.html.twig' %}

{% block title %}Minifacturier{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="mb-3">Bienvenue sur Minifacturier</h1>
        <p class="lead">
            Application de gestion de clients, vendeurs et factures
        </p>
        <p class="text-muted">et consultation du catalogue</p>
    </div>

    <div class="row text-center">

        <div class="col-md-4 mb-4">
            <h3><i class="fa-solid fa-circle-user"></i> Clients</h3>
            <p>Gérer les informations de vos clients</p>
            <a href="{{ path('app_customer_index') }}" class="btn btn-primary">
                Voir les clients
            </a>
        </div>

        <div class="col-md-4 mb-4">
            <h3><i class="fa-regular fa-circle-user"></i> Vendeurs</h3>
            <p>Consulter et modifier les vendeurs</p>
            <a href="{{ path('app_seller_index') }}" class="btn btn-primary">
                Voir les vendeurs
            </a>
        </div>

        <div class="col-md-4 mb-4">
            <h3><i class="fa-solid fa-euro-sign"></i> Factures</h3>
            <p>Créer et suivre les factures</p>
            <a href="{{ path('app_invoice_index') }}" class="btn btn-primary">
                Voir les factures
            </a>
        </div>

        <div class="col-md-6 mb-4">
            <h3><i class="fa fa-book" aria-hidden="true"></i> Catalogue</h3>
            <p>Consulter les produits disponibles</p>
            <a href="{{ path('app_catalog_index') }}" class="btn btn-warning">
                Voir le catalogue
            </a>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="col-md-6 mb-4">
                <h3><i class="fa fa-line-chart" aria-hidden="true"></i> Statistiques</h3>
                <p>Analyser vos ventes et performances</p>
                <a href="{{ path('app_stats_index') }}" class="btn btn-info">
                    Voir les statistiques
                </a>
            </div>
        {% endif %}

    </div>

</div>
{% endblock %}