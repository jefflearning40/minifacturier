{% extends 'base.html.twig' %}

{% block title %}Gestion des produits{% endblock %}

{% block main_class %}container-fluid p-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
{% endblock %}

{% block body %}
<section class="product-section">

    <div class="product-wrapper">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Gestion des produits</h1>

            <a href="{{ path('app_product_new') }}" class="btn btn-primary">
                Ajouter un produit
            </a>
        </div>

        <div class="product-table-wrapper">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th>Nom</th>
                        <th>Marque</th>
                        <th class="text-end">Prix HT</th>
                        <th class="text-end">TVA (%)</th>
                        <th class="text-end">Prix TTC</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {% for product in products %}
                        <tr>
                            <td>{{ product.name }}</td>
                            <td>{{ product.brand }}</td>
                            <td class="text-end">{{ product.price|number_format(2, ',', ' ') }} €</td>
                            <td class="text-end">{{ product.vatRate|number_format(2, ',', ' ') }}</td>
                            <td class="text-end">
                                {{ (product.price * (1 + product.vatRate / 100))|number_format(2, ',', ' ') }} €
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">

                                    {{ include('components/buttons/_show.html.twig', {
                                        route: 'app_product_show',
                                        id: product.id
                                    }) }}

                                    {{ include('components/buttons/_edit.html.twig', {
                                        route: 'app_product_edit',
                                        id: product.id
                                    }) }}

                                    {{ include('components/buttons/_delete.html.twig', {
                                        route: 'app_product_delete',
                                        id: product.id
                                    }) }}

                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-white">
                                Aucun produit disponible.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>

</section>
{% endblock %}