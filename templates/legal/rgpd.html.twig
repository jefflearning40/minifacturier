{% extends 'base.html.twig' %}

{% block title %}Politique RGPD{% endblock %}

{% block main_class %}container-fluid px-0 pt-4 pb-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/legal.css') }}">
{% endblock %}

{% block body %}
<section class="legal-section">

    <div class="legal-card legal-rgpd-card">

        <h1 class="mb-3">
            <i class="fa-solid fa-shield-halved me-2"></i>
            Politique de confidentialité
        </h1>

        <p class="legal-intro">
            L'application MiniFacturier collecte certaines données personnelles
            dans le cadre de son fonctionnement.
        </p>

        <div class="legal-block">
            <h2>Données collectées</h2>
            <p>Nom, prénom, adresse email et informations liées aux factures.</p>
        </div>

        <div class="legal-block">
            <h2>Finalité</h2>
            <p>Gestion des factures et communication via le formulaire de contact.</p>
        </div>

        <div class="legal-block">
            <h2>Sécurité</h2>
            <p>Données accessibles uniquement aux utilisateurs autorisés. Aucun partage avec des tiers.</p>
        </div>

        <div class="legal-block">
            <h2>Droits</h2>
            <p>Droit d’accès, modification et suppression de vos données.</p>
        </div>

        <div class="legal-block">
            <h2>Contact</h2>
            <p><strong>contact@minifacturier.com</strong></p>
        </div>

    </div>

</section>
{% endblock %}