{% extends 'base.html.twig' %}

{% block title %}Contact{% endblock %}

{% block main_class %}container-fluid px-0 pt-4 pb-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/legal.css') }}">
{% endblock %}

{% block body %}
<section class="legal-section">

    <div class="legal-card legal-contact-card">

        <div class="legal-header">
            <h1>Contact</h1>
            <p>Une question, une remarque ou un besoin d’information ? Contactez MiniFacturier.</p>
        </div>

        <div class="row g-4">

            <div class="col-md-5">
                <div class="legal-info-box h-100">
                    <h2>
                        <i class="fa-solid fa-address-card me-2"></i>
                        Informations
                    </h2>

                    <p>
                        <i class="fa-solid fa-phone me-2"></i>
                        06 00 00 00 00
                    </p>

                    <p>
                        <i class="fa-solid fa-envelope me-2"></i>
                        contact@minifacturier.com
                    </p>

                    <p>
                        <i class="fa-solid fa-location-dot me-2"></i>
                        1 rue de la ville, 40 les landes
                    </p>

                    <div class="legal-note">
                        MiniFacturier est une application de gestion de factures réalisée dans le cadre d’un projet d’examen.
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="legal-form-box">

                    <h2>
                        <i class="fa-solid fa-paper-plane me-2"></i>
                        Envoyer un message
                    </h2>

                    <form method="post" action="{{ path('app_contact') }}">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="firstname" class="form-label">Prénom</label>
                                <input type="text" id="firstname" name="firstname" class="form-control" required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="lastname" class="form-label">Nom</label>
                                <input type="text" id="lastname" name="lastname" class="form-control" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Adresse email</label>
                            <input type="email" id="email" name="email" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label for="message" class="form-label">Message</label>
                            <textarea id="message" name="message" rows="5" class="form-control" required></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="{{ path('app_home') }}" class="btn btn-back">
                                <i class="bi bi-arrow-left me-1"></i>
                                Annuler
                            </a>

                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-paper-plane me-1"></i>
                                Envoyer
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>

    </div>

</section>
{% endblock %}