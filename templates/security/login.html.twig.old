                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{{ path('app_invoice_index') }}">Liste des factures</a></li>

                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SELLER') %}
