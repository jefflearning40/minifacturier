                        {% if is_granted('ROLE_ADMIN') %}
                            <li><a class="dropdown-item" href="{{ path('app_seller_new') }}">Ajouter un vendeur</a></li>
                        {% endif %}
                    </ul>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_catalog_index') }}">
                        <i class="fa-solid fa-book me-1"></i> Catalogue
                    </a>
                </li>

 {# ===== MAILPIT ===== #}
{% if is_granted('ROLE_ADMIN') %}
