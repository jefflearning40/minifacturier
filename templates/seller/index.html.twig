{% extends 'base.html.twig' %}

{% block title %}Liste des vendeurs{% endblock %}

{% block body %}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Liste des vendeurs</h1>

        {#
        <a href="{{ path('app_seller_new') }}" class="btn btn-success">
            + Nouveau vendeur
        </a>
        #}
    </div>

    <div style="max-height: 450px; overflow-y: auto;" class="border">
        <table class="table table-striped table-hover table-bordered mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th>Id</th>
                    <th>Nom complet</th>
                    <th>Téléphone</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
            {% for seller in sellers %}
                <tr>
                    <td>{{ seller.id }}</td>

                    <td>
                        {{ seller.firstNameSeller }}
                        {{ seller.lastNameSeller|upper }}

                        {% if seller.invoices|length == 0 %}
                            <span class="ms-2 text-danger" title="Aucune vente réalisée">●</span>
                        {% else %}
                            <span class="ms-2 text-success" title="Ventes réalisées">●</span>
                        {% endif %}
                    </td>

                    <td>{{ seller.phoneSeller }}</td>

                    <td class="text-center">
                        {{ include('components/buttons/_show.html.twig', {
                            route: 'app_seller_show',
                            id: seller.id
                        }) }}

                        {{ include('components/buttons/_edit.html.twig', {
                            route: 'app_seller_edit',
                            id: seller.id
                        }) }}

                        {{ include('components/buttons/_delete.html.twig', {
                            route: 'app_seller_delete',
                            id: seller.id
                        }) }}
                    </td>
                </tr>

            {% else %}
                <tr>
                    <td colspan="4" class="text-center">
                        Aucun vendeur trouvé
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">

        {{ include('components/buttons/_prev.html.twig', {
            pagination: sellers
        }) }}

        <span class="fw-bold">
            Page {{ sellers.currentPageNumber }} / {{ sellers.pageCount }}
        </span>

        {{ include('components/buttons/_next.html.twig', {
            pagination: sellers
        }) }}

    </div>

    <div class="text-center text-muted mt-2">
        {{ sellers.getTotalItemCount }} vendeurs au total
    </div>

</div>

{% endblock %}