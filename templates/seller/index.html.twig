{% extends 'base.html.twig' %}

{% block title %}Liste des vendeurs{% endblock %}

{% block main_class %}container-fluid p-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/seller.css') }}">
{% endblock %}

{% block body %}
<section class="seller-section">

    <div class="seller-wrapper">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Liste des vendeurs</h1>
        </div>

        <div class="seller-table-wrapper">
            <table class="table table-striped table-hover table-bordered mb-0">

                <thead class="table-dark sticky-top">
                    <tr>
                        <th>Id</th>
                        <th>Nom complet</th>
                        <th>Téléphone</th>
                        <th class="text-center seller-actions-col">Actions</th>
                        <th class="text-center seller-account-col">Compte</th>
                    </tr>
                </thead>

                <tbody>
                {% for seller in sellers %}
                    <tr>
                        <td>{{ seller.id }}</td>

                        <td>
                            {{ seller.firstNameSeller }}
                            {{ seller.lastNameSeller|upper }}

                            {% if seller.invoices|length > 0 %}
                                <span class="badge bg-success ms-2">Actif</span>
                            {% else %}
                                <span class="badge bg-danger ms-2">Inactif</span>
                            {% endif %}

                            {% if seller.user %}
                                <span class="badge bg-primary ms-2">Compte</span>
                            {% endif %}
                        </td>

                        <td>{{ seller.phoneSeller }}</td>

                        <td class="text-center seller-actions-col">
                            <div class="seller-actions-buttons">
                                {{ include('components/buttons/_show.html.twig', {
                                    route: 'app_seller_show',
                                    id: seller.id
                                }) }}

                                {% if is_granted('ROLE_ADMIN') %}
                                    {{ include('components/buttons/_edit.html.twig', {
                                        route: 'app_seller_edit',
                                        id: seller.id
                                    }) }}

                                    {% if seller.invoices|length > 0 %}
                                        <button
                                            type="button"
                                            class="btn btn-sm btn-secondary"
                                            disabled
                                            title="Suppression impossible : vendeur lié à une facture"
                                        >
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    {% else %}
                                        {{ include('components/buttons/_delete.html.twig', {
                                            route: 'app_seller_delete',
                                            id: seller.id
                                        }) }}
                                    {% endif %}
                                {% endif %}
                            </div>
                        </td>

                        <td class="text-center seller-account-col">
                            {% if is_granted('ROLE_ADMIN') and seller.user %}
                                <button
                                    type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    data-bs-toggle="modal"
                                    data-bs-target="#sellerLoginModal{{ seller.id }}"
                                    title="Voir les identifiants"
                                >
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                    </tr>

                    {% if is_granted('ROLE_ADMIN') and seller.user %}
                        <div class="modal fade" id="sellerLoginModal{{ seller.id }}" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">

                                    <div class="modal-header bg-dark text-white">
                                        <h5 class="modal-title">
                                            Identifiants vendeur
                                        </h5>

                                        <button
                                            type="button"
                                            class="btn-close btn-close-white"
                                            data-bs-dismiss="modal">
                                        </button>
                                    </div>

                                    <div class="modal-body">
                                        <p>
                                            <strong>Vendeur :</strong>
                                            {{ seller.firstNameSeller }} {{ seller.lastNameSeller|upper }}
                                        </p>

                                        <p>
                                            <strong>Email :</strong>
                                            {{ seller.user.email }}
                                        </p>

                                        <p>
                                            <strong>Mot de passe :</strong>
                                            seller{{ seller.id }}
                                        </p>

                                        <div class="alert alert-info small mb-0">
                                            En cas de perte des identifiants, le vendeur peut contacter
                                            l’entreprise via le footer ou le téléphone interne.
                                        </div>
                                    </div>

                                    <div class="modal-footer">
                                        <a
                                            href="{{ path('app_seller_resend_login', {'id': seller.id}) }}"
                                            class="btn btn-primary">
                                            <i class="fa-solid fa-paper-plane me-1"></i>
                                            Renvoyer dans Mailpit
                                        </a>

                                        <button
                                            type="button"
                                            class="btn btn-secondary"
                                            data-bs-dismiss="modal">
                                            Fermer
                                        </button>
                                    </div>

                                </div>
                            </div>
                        </div>
                    {% endif %}

                {% else %}
                    <tr>
                        <td colspan="5" class="text-center">
                            Aucun vendeur trouvé
                        </td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>
        </div>

        <div class="seller-pagination d-flex justify-content-center align-items-center gap-3 mt-4">

            {{ include('components/buttons/_prev.html.twig', {
                pagination: sellers
            }) }}

            <span class="fw-bold">
                Page {{ sellers.currentPageNumber }} / {{ sellers.pageCount }}
            </span>

            {{ include('components/buttons/_next.html.twig', {
                pagination: sellers
            }) }}

        </div>

        <div class="seller-total text-center mt-2">
            {{ sellers.getTotalItemCount }} vendeurs au total
        </div>

    </div>

</section>
{% endblock %}