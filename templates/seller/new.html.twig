{% extends 'base.html.twig' %}

{% block title %}Nouveau vendeur{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="mb-4">Créer un nouveau vendeur</h1>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            {{ include('seller/_form.html.twig', {
                button_label: 'Enregistrer',
                button_class: 'btn-success'
            }) }}

            <div class="mt-4">
                {{ include('components/buttons/_back.html.twig', {
                    route: 'app_seller_index'
                }) }}
            </div>

        </div>
    </div>

</div>
{% endblock %}