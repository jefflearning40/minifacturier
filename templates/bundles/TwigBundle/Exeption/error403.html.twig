{% extends 'base.html.twig' %}

{% block title %}Accès refusé{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">

            <div class="mt-5 mb-4">
                <i class="bi bi-shield-lock-fill text-danger" style="font-size: 5rem;"></i>
            </div>

            <h1 class="display-5 fw-bold mb-4">
                <i class="bi bi-exclamation-octagon-fill text-danger me-2"></i>
                Accès refusé
            </h1>

            <h3 class="text-secondary mb-4">
                Autorisation insuffisante
            </h3>

            <p class="lead">
                <i class="bi bi-person-lock me-2"></i>
                Vous ne disposez pas des droits nécessaires pour accéder à cette page.
            </p>

            <p class="text-muted mb-5">
                Si vous pensez qu'il s'agit d'une erreur, contactez un administrateur.
            </p>

            <a href="{{ path('app_home') }}" class="btn btn-primary btn-lg">
                <i class="bi bi-house-door me-2"></i>
                Retour à l'accueil
            </a>

        </div>
    </div>

</div>
{% endblock %}