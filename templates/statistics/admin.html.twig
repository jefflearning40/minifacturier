{% extends 'base.html.twig' %}

{% block title %}Statistiques admin{% endblock %}

{% block main_class %}container-fluid px-0 pt-4 pb-0{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/statistics.css') }}">
{% endblock %}

{% block body %}
<section class="stats-section">

    <div class="container">
        <div class="stats-dashboard">

            <div class="stats-dashboard-header">
                <div>
                    <h1>Tableau de bord admin</h1>
                    <p>Vue globale de l’activité MiniFacturier</p>
                </div>

                <button class="btn btn-primary stats-chart-button" data-bs-toggle="modal" data-bs-target="#statsModal">
                    <i class="fa-solid fa-chart-line me-2"></i>
                    Voir les graphiques
                </button>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="stats-kpi-card">
                        <div class="stats-kpi-icon bg-primary-subtle text-primary">
                            <i class="fa-solid fa-user-tie"></i>
                        </div>
                        <div>
                            <div class="stats-kpi-label">Vendeurs</div>
                            <div class="stats-kpi-value">{{ totalSellers }}</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="stats-kpi-card">
                        <div class="stats-kpi-icon bg-success-subtle text-success">
                            <i class="fa-solid fa-user-group"></i>
                        </div>
                        <div>
                            <div class="stats-kpi-label">Clients</div>
                            <div class="stats-kpi-value">{{ totalCustomers }}</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="stats-kpi-card">
                        <div class="stats-kpi-icon bg-warning-subtle text-warning">
                            <i class="fa-solid fa-file-invoice-dollar"></i>
                        </div>
                        <div>
                            <div class="stats-kpi-label">Factures</div>
                            <div class="stats-kpi-value">{{ totalInvoices }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">

                <div class="col-lg-6">
                    <div class="stats-panel stats-sales-panel h-100">
                        <div class="stats-panel-title">
                            <i class="fa-solid fa-sack-dollar me-2"></i>
                            Chiffre d'affaires global
                        </div>

                        <div class="stats-total-main">
                            {{ totalSalesTtc|number_format(2, ',', ' ') }} €
                        </div>
                        <div class="text-muted small mb-4">Total TTC</div>

                        <div class="stats-sales-lines">
                            <div>
                                <span>Total HT</span>
                                <strong>{{ totalSalesHt|number_format(2, ',', ' ') }} €</strong>
                            </div>
                            <div>
                                <span>Total TVA</span>
                                <strong>{{ totalVat|number_format(2, ',', ' ') }} €</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="stats-panel h-100">
                        <div class="stats-panel-title">
                            <i class="fa-solid fa-boxes-stacked me-2"></i>
                            Résumé produits
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="stats-product-card">
                                    <div class="stats-product-badge bg-success">
                                        Plus vendu
                                    </div>

                                    {% if mostSoldProduct %}
                                        <div class="fw-bold">{{ mostSoldProduct.productName }}</div>
                                        <div class="text-muted small">{{ mostSoldProduct.brand }}</div>
                                        <div class="mt-3">
                                            Quantité :
                                            <strong>{{ mostSoldProduct.totalQuantity }}</strong>
                                        </div>
                                    {% else %}
                                        <div class="text-muted small">Aucune donnée</div>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="stats-product-card">
                                    <div class="stats-product-badge bg-danger">
                                        Moins vendu
                                    </div>

                                    {% if leastSoldProduct %}
                                        <div class="fw-bold">{{ leastSoldProduct.productName }}</div>
                                        <div class="text-muted small">{{ leastSoldProduct.brand }}</div>
                                        <div class="mt-3">
                                            Quantité :
                                            <strong>{{ leastSoldProduct.totalQuantity }}</strong>
                                        </div>
                                    {% else %}
                                        <div class="text-muted small">Aucune donnée</div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <div class="row g-3">

                <div class="col-lg-7">
                    <div class="stats-panel h-100">
                        <div class="stats-panel-title">
                            <i class="fa-solid fa-ranking-star me-2"></i>
                            Produits vendus par quantité
                        </div>

                        <div class="stats-table-wrapper">
                            <table class="table table-bordered table-sm align-middle mb-0">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        <th>Produit</th>
                                        <th>Marque</th>
                                        <th class="text-end">Quantité</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for product in salesByProduct %}
                                        <tr>
                                            <td>{{ product.productName }}</td>
                                            <td class="text-muted">{{ product.brand }}</td>
                                            <td class="text-end fw-semibold">{{ product.totalQuantity }}</td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="3" class="text-center text-muted">
                                                Aucune vente enregistrée.
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="stats-panel h-100">
                        <div class="stats-panel-title">
                            <i class="fa-solid fa-receipt me-2"></i>
                            Factures par vendeur
                        </div>

                        <div class="stats-table-wrapper">
                            <table class="table table-bordered table-sm align-middle mb-0">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        <th>Vendeur</th>
                                        <th class="text-end">Factures</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for seller in invoiceCountBySeller %}
                                        <tr>
                                            <td>{{ seller.firstName }} {{ seller.lastName|upper }}</td>
                                            <td class="text-end">
                                                {% if seller.totalInvoices == 0 %}
                                                    <span class="badge bg-danger">{{ seller.totalInvoices }}</span>
                                                {% else %}
                                                    <span class="badge bg-success">{{ seller.totalInvoices }}</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="2" class="text-center text-muted">
                                                Aucune donnée disponible.
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>

</section>

<div class="modal fade" id="statsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content stats-modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">
                    <i class="fa-solid fa-chart-line me-2"></i>
                    Graphique - Chiffre d'affaires TTC
                </h5>

                <button
                    type="button"
                    class="btn-close btn-close-white"
                    data-bs-dismiss="modal"
                ></button>
            </div>

            <div class="modal-body">
                <canvas
                    id="salesEvolutionChart"
                    data-labels="{{ salesEvolution|map(s => s.saleDate|date('d/m/Y'))|json_encode|e('html_attr') }}"
                    data-values="{{ salesEvolution|map(s => s.totalTtc)|json_encode|e('html_attr') }}"
                ></canvas>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="{{ asset('js/admin.js') }}"></script>
{% endblock %}