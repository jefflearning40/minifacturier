{% extends 'base.html.twig' %}

{% block title %}Statistiques admin{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Tableau de bord admin</h1>

        <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#statsModal">
            Voir graphiques
        </button>
    </div>

    <div class="row text-center g-3 mb-4">
        <div class="col-md-4">
            <div class="border p-3 h-100">
                <div class="text-muted small text-uppercase">Vendeurs</div>
                <div class="fs-3 fw-bold">{{ totalSellers }}</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="border p-3 h-100">
                <div class="text-muted small text-uppercase">Clients</div>
                <div class="fs-3 fw-bold">{{ totalCustomers }}</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="border p-3 h-100">
                <div class="text-muted small text-uppercase">Factures</div>
                <div class="fs-3 fw-bold">{{ totalInvoices }}</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-lg-6">
            <div class="border p-4 h-100">
                <h4 class="mb-3">Chiffre d'affaires global</h4>

                <table class="table table-sm w-auto ms-auto text-end mb-0">
                    <tr>
                        <th>Total HT</th>
                        <td>{{ totalSalesHt|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    <tr>
                        <th>Total TVA</th>
                        <td>{{ totalVat|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    <tr class="fw-bold">
                        <th>Total TTC</th>
                        <td>{{ totalSalesTtc|number_format(2, ',', ' ') }} €</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="border p-4 h-100">
                <h4 class="mb-3">Résumé produits</h4>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border p-3 h-100">
                            <h6 class="mb-2">Plus vendu</h6>

                            {% if mostSoldProduct %}
                                <div class="fw-bold">{{ mostSoldProduct.productName }}</div>
                                <div class="text-muted small mb-2">{{ mostSoldProduct.brand }}</div>
                                <div class="small">
                                    Quantité :
                                    <strong>{{ mostSoldProduct.totalQuantity }}</strong>
                                </div>
                            {% else %}
                                <div class="text-muted small">Aucune donnée</div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border p-3 h-100">
                            <h6 class="mb-2">Moins vendu</h6>

                            {% if leastSoldProduct %}
                                <div class="fw-bold">{{ leastSoldProduct.productName }}</div>
                                <div class="text-muted small mb-2">{{ leastSoldProduct.brand }}</div>
                                <div class="small">
                                    Quantité :
                                    <strong>{{ leastSoldProduct.totalQuantity }}</strong>
                                </div>
                            {% else %}
                                <div class="text-muted small">Aucune donnée</div>
                            {% endif %}
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <div class="border p-4">
        <h4 class="mb-3">Produits vendus par quantité</h4>

        <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
            <table class="table table-bordered table-sm align-middle mb-0">
                <thead class="table-light sticky-top">
                    <tr>
                        <th>Produit</th>
                        <th>Marque</th>
                        <th class="text-end">Quantité vendue</th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in salesByProduct %}
                        <tr>
                            <td>{{ product.productName }}</td>
                            <td class="text-muted">{{ product.brand }}</td>
                            <td class="text-end">{{ product.totalQuantity }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center text-muted">
                                Aucune vente enregistrée.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="border p-4 mt-4">
        <h4 class="mb-3">Nombre de factures par vendeur</h4>

        <div class="table-responsive" style="max-height: 320px; overflow-y: auto;">
            <table class="table table-bordered table-sm align-middle mb-0">
                <thead class="table-light sticky-top">
                    <tr>
                        <th>Vendeur</th>
                        <th class="text-end">Nombre de factures</th>
                    </tr>
                </thead>
                <tbody>
                    {% for seller in invoiceCountBySeller %}
                        <tr>
                            <td>{{ seller.firstName }} {{ seller.lastName|upper }}</td>
                            <td class="text-end">
                                {% if seller.totalInvoices == 0 %}
                                    <span class="badge bg-danger">{{ seller.totalInvoices }}</span>
                                {% else %}
                                    <span class="badge bg-success">{{ seller.totalInvoices }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-center text-muted">
                                Aucune donnée disponible.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>

<div class="modal fade" id="statsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Graphique - Factures par vendeur</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <canvas id="sellerChart"></canvas>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modal = document.getElementById('statsModal');
            const canvas = document.getElementById('sellerChart');

            if (!modal || !canvas) return;

            const labels = {{ invoiceCountBySeller|map(s => s.firstName ~ ' ' ~ s.lastName)|json_encode|raw }};
            const values = {{ invoiceCountBySeller|map(s => s.totalInvoices)|json_encode|raw }};

            let chart = null;

            modal.addEventListener('shown.bs.modal', function () {
                if (chart) {
                    chart.destroy();
                }

                chart = new Chart(canvas, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Nombre de factures',
                            data: values,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            });
        });
    </script>
{% endblock %}