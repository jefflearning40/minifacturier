{% extends 'base.html.twig' %}

{% block title %}Mes statistiques{% endblock %}

{# IMPORTANT : centrage ici #}
{% block main_class %}container py-4{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('assets/styles/seller_statistics.css') }}">
{% endblock %}

{% block body %}

<div class="seller-stats-wrapper">

    <div class="seller-stats-card">

        <!-- HEADER -->
        <div class="stats-header">
            <h1>Mes statistiques</h1>
            <p>
                Vendeur :
                <strong>{{ seller.lastNameSeller|upper }} {{ seller.firstNameSeller }}</strong>
            </p>
        </div>

        <!-- KPI -->
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="stats-kpi-card">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                    <div>
                        <span>Mes factures</span>
                        <strong>{{ totalInvoices }}</strong>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="stats-kpi-card success">
                    <i class="fa-solid fa-boxes-stacked"></i>
                    <div>
                        <span>Produits vendus</span>
                        <strong>{{ totalProductsSold }}</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- CONTENU -->
        <div class="row g-4">

            <!-- CA -->
            <div class="col-lg-5">
                <div class="stats-card h-100">

                    <h3>Mes ventes</h3>

                    <div class="stats-total">
                        {{ totalSalesTtc|number_format(2, ',', ' ') }} €
                    </div>

                    <div class="stats-sub">Total TTC</div>

                    <div class="stats-lines">
                        <div>
                            <span>Total HT</span>
                            <strong>{{ totalSalesHt|number_format(2, ',', ' ') }} €</strong>
                        </div>

                        <div>
                            <span>Total TVA</span>
                            <strong>{{ totalVat|number_format(2, ',', ' ') }} €</strong>
                        </div>
                    </div>

                </div>
            </div>

            <!-- TABLE -->
            <div class="col-lg-7">
                <div class="stats-card h-100">

                    <h3>Produits vendus</h3>

                    <div class="table-wrapper">
                        <table class="table table-bordered table-sm align-middle mb-0">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th>Produit</th>
                                    <th>Marque</th>
                                    <th class="text-end">Quantité</th>
                                </tr>
                            </thead>

                            <tbody>
                                {% for product in salesByProduct %}
                                    <tr>
                                        <td>{{ product.productName }}</td>
                                        <td class="text-muted">{{ product.brand }}</td>
                                        <td class="text-end fw-semibold">
                                            {{ product.totalQuantity }}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center text-muted">
                                            Aucune vente
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

        </div>

    </div>

</div>

{% endblock %}