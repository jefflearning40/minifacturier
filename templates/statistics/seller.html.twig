{% extends 'base.html.twig' %}

{% block title %}Mes statistiques{% endblock %}

{% block main_class %}seller-main flex-grow-1{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/seller_statistics.css') }}">
{% endblock %}

{% block body %}

<section class="seller-dashboard">

    <div class="dashboard-container">

        <div class="dashboard-header">
            <div>
                <h1>Mes statistiques</h1>
                <p>
                    Vendeur :
                    <strong>{{ seller.lastNameSeller|upper }} {{ seller.firstNameSeller }}</strong>
                </p>
            </div>

            <div class="dashboard-badge">
                <i class="fa-solid fa-chart-line"></i>
                Tableau vendeur
            </div>
        </div>

        <div class="stats-grid">

            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                </div>

                <div>
                    <span>Mes factures</span>
                    <strong>{{ totalInvoices }}</strong>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-boxes-stacked"></i>
                </div>

                <div>
                    <span>Produits vendus</span>
                    <strong>{{ totalProductsSold }}</strong>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="fa-solid fa-euro-sign"></i>
                </div>

                <div>
                    <span>Total TTC</span>
                    <strong>{{ totalSalesTtc|number_format(2, ',', ' ') }} €</strong>
                </div>
            </div>

        </div>

        <div class="dashboard-content">

            <article class="panel-card sales-card">
                <div class="panel-header">
                    <h2>Mes ventes</h2>
                    <i class="fa-solid fa-coins"></i>
                </div>

                <div class="big-total">
                    {{ totalSalesTtc|number_format(2, ',', ' ') }} €
                </div>

                <p>Total TTC</p>

                <div class="amount-list">
                    <div>
                        <span>Total HT</span>
                        <strong>{{ totalSalesHt|number_format(2, ',', ' ') }} €</strong>
                    </div>

                    <div>
                        <span>Total TVA</span>
                        <strong>{{ totalVat|number_format(2, ',', ' ') }} €</strong>
                    </div>
                </div>
            </article>

            <article class="panel-card products-card">
                <div class="panel-header">
                    <h2>Produits vendus</h2>
                    <i class="fa-solid fa-box-open"></i>
                </div>

                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>Marque</th>
                                <th>Quantité</th>
                            </tr>
                        </thead>

                        <tbody>
                            {% for product in salesByProduct %}
                                <tr>
                                    <td>{{ product.productName }}</td>
                                    <td>{{ product.brand }}</td>
                                    <td class="quantity">{{ product.totalQuantity }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="empty-table">
                                        Aucune vente pour le moment.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </article>

        </div>

    </div>

</section>

{% endblock %}