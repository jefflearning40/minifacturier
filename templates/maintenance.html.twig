{% extends 'base.html.twig' %}

{% block title %}Projet en développement{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">

            <div class="mt-5 mb-4">
                <i class="bi bi-tools text-warning" style="font-size: 5rem;"></i>
            </div>

            <h1 class="display-5 fw-bold mb-4">
                <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                Projet d'amélioration du site
            </h1>

            <h3 class="text-secondary mb-4">
                Scanner et signature électronique des devis
            </h3>

            <p class="lead">
                <i class="bi bi-hourglass-split me-2"></i>
                Cette fonctionnalité sera bientôt disponible.
            </p>

            <p class="text-muted mb-5">
                Merci de votre patience.
            </p>

            <a href="{{ path('app_home') }}" class="btn btn-primary btn-lg">
                <i class="bi bi-house-door me-2"></i>
                Retour à l'accueil
            </a>

        </div>
    </div>

</div>
{% endblock %}