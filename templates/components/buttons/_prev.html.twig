{% set prevPage = pagination.currentPageNumber > 1
    ? pagination.currentPageNumber - 1
    : pagination.pageCount %}

<a href="{{ path(app.request.attributes.get('_route'), app.request.query.all | merge({'page': prevPage})) }}"
   class="btn btn-primary btn-sm btn-pagination">
    <i class="fa-solid fa-arrow-left"></i>
</a>