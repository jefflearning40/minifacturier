                                <i class="fa-solid fa-list me-2"></i>
                                Liste des clients
                            </a>
                        </li>

                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_SELLER') %}
                            <li>
                                <a class="dropdown-item" href="{{ path('app_customer_new') }}">
                                    <i class="fa-solid fa-plus me-2"></i>
                                    Ajouter un client
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </li>

                <li class="nav-item dropdown">
                    <a
