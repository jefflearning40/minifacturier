                                <a class="dropdown-item" href="{{ path('app_seller_new') }}">
                                    <i class="fa-solid fa-plus me-2"></i>
                                    Ajouter un vendeur
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="{{ path('app_admin_create_seller_user') }}">
                                    <i class="fa-solid fa-user-plus me-2"></i>
