{% extends 'base.html.twig' %}

{% block title %}Catalogue{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Catalogue</h1>
            <p class="text-muted mb-0">Liste des produits disponibles</p>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_product_new') }}" class="btn btn-primary">
                Ajouter un produit
            </a>
        {% endif %}
    </div>

    <form method="get" class="mb-4">
        <div class="row g-2 align-items-center">

            <div class="col-md-4">
                <input
                    type="text"
                    name="search"
                    value="{{ search }}"
                    class="form-control"
                    placeholder="Rechercher un produit..."
                >
            </div>

            <div class="col-md-4">
                <select name="brand" class="form-select">
                    <option value="">Toutes les marques</option>

                    {% for itemBrand in brands %}
                        <option value="{{ itemBrand }}" {% if brand == itemBrand %}selected{% endif %}>
                            {{ itemBrand }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-auto">
                <button class="btn btn-primary">
                    Filtrer
                </button>
            </div>

            {% if search or brand %}
                <div class="col-auto">
                    <a href="{{ path('app_catalog_index') }}" class="btn btn-outline-secondary">
                        Réinitialiser
                    </a>
                </div>
            {% endif %}

        </div>
    </form>

    {% if search or brand %}
        <p class="text-muted">
            {% if search %}
                Recherche : <strong>{{ search }}</strong>
            {% endif %}

            {% if search and brand %}
                —
            {% endif %}

            {% if brand %}
                Marque : <strong>{{ brand }}</strong>
            {% endif %}
        </p>
    {% endif %}

    <div style="max-height: 450px; overflow-y: auto;" class="border">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th>Nom</th>
                    <th>Marque</th>
                    <th class="text-end">Prix HT</th>
                    <th class="text-end">TVA (%)</th>
                    <th class="text-end">Prix TTC</th>

                    {% if is_granted('ROLE_ADMIN') %}
                        <th class="text-center">Actions</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr>
                        <td>{{ product.name }}</td>
                        <td>{{ product.brand }}</td>
                        <td class="text-end">{{ product.price|number_format(2, ',', ' ') }} €</td>
                        <td class="text-end">{{ product.vatRate|number_format(2, ',', ' ') }}</td>
                        <td class="text-end">
                            {{ (product.price * (1 + product.vatRate / 100))|number_format(2, ',', ' ') }} €
                        </td>

                        {% if is_granted('ROLE_ADMIN') %}
                            <td class="text-center">
                                {{ include('components/buttons/_show.html.twig', {
                                    route: 'app_product_show',
                                    id: product.id
                                }) }}

                                {{ include('components/buttons/_edit.html.twig', {
                                    route: 'app_product_edit',
                                    id: product.id
                                }) }}

                                {{ include('components/buttons/_delete.html.twig', {
                                    route: 'app_product_delete',
                                    id: product.id
                                }) }}
                            </td>
                        {% endif %}
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="{% if is_granted('ROLE_ADMIN') %}6{% else %}5{% endif %}" class="text-center text-muted">
                            Aucun produit disponible.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">

        {{ include('components/buttons/_prev.html.twig', {
            pagination: products
        }) }}

        <span class="fw-bold">
            Page {{ products.currentPageNumber }} / {{ products.pageCount }}
        </span>

        {{ include('components/buttons/_next.html.twig', {
            pagination: products
        }) }}

    </div>

    <div class="text-center text-muted mt-2">
        {{ products.getTotalItemCount }} produits au total
    </div>

</div>
{% endblock %}