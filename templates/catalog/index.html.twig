{% extends 'base.html.twig' %}

{% block title %}Catalogue{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Catalogue</h1>
            <p class="text-muted mb-0">Liste des produits disponibles</p>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <a href="#" class="btn btn-primary">
                Ajouter un produit
            </a>
        {% endif %}
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nom</th>
                    <th>Marque</th>
                    <th class="text-end">Prix HT</th>
                    <th class="text-end">TVA (%)</th>
                    <th class="text-end">Prix TTC</th>

                    {% if is_granted('ROLE_ADMIN') %}
                        <th class="text-center">Actions</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr>
                        <td>{{ product.name }}</td>
                        <td>{{ product.brand }}</td>
                        <td class="text-end">{{ product.price|number_format(2, ',', ' ') }} €</td>
                        <td class="text-end">{{ product.vatRate|number_format(2, ',', ' ') }}</td>
                        <td class="text-end">
                            {{ (product.price * (1 + product.vatRate / 100))|number_format(2, ',', ' ') }} €
                        </td>

                        {% if is_granted('ROLE_ADMIN') %}
                            <td class="text-center">
                                <a href="#" class="btn btn-sm btn-outline-secondary">Modifier</a>
                                <a href="#" class="btn btn-sm btn-outline-danger">Supprimer</a>
                            </td>
                        {% endif %}
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="{% if is_granted('ROLE_ADMIN') %}6{% else %}5{% endif %}" class="text-center text-muted">
                            Aucun produit disponible.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}